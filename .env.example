# Get these from https://console.agora.io -> your project
AGORA_APP_ID=your_app_id_here

# Leave blank to run in "testing mode" (no token auth -- fine for a quick
# local POC). Fill in once you enable the App Certificate in the console,
# which is required before going to production.
AGORA_APP_CERTIFICATE=

# How long an issued token stays valid, in seconds (max allowed: 86400 = 24h)
AGORA_TOKEN_TTL_SECONDS=3600

# Secret used to sign per-room host links (the ?host=<token> capability that
# unlocks the recording/snapshot controls). Optional: if blank, the app falls
# back to the App Certificate, then to a random per-process key (host links
# reset on restart in that case). Set any long random string to keep them
# stable across restarts.
ROOM_SIGNING_SECRET=

# Public HTTPS address this app is reached at (VS Code tunnel / ngrok / proxy),
# used to build shareable invite links. Leave blank to use the request's own
# host. Example: https://your-tunnel-id.devtunnels.ms
PUBLIC_BASE_URL=
